# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=nvidia-driver-assistant
pkgver=0.51.71.05_1.g8f2a1b3c4d
pkgrel=1
pkgdesc="NVIDIA Driver Assistant for Manjaro, tracking the latest official NVIDIA DEB"
arch=('any')
url="https://github.com/megvadulthangya/nvidia-driver-assistant"
license=('MIT' 'custom')
depends=('python')
makedepends=('git' 'curl' 'libarchive' 'gzip')

source=("git+https://github.com/megvadulthangya/nvidia-driver-assistant.git#branch=refactor")
sha256sums=('SKIP')

_nvidia_repo_base='https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64'

_latest_deb_info() {
  local html latest_file ver
  
  # HTML lista lekérése
  html=$(curl -fsSL --retry 3 --retry-delay 2 --connect-timeout 10 "${_nvidia_repo_base}/") || return 1
  
  # A legfrissebb verziójú .deb fájl kiválasztása
  latest_file=$(echo "$html" | grep -oP 'nvidia-driver-assistant_[\d\.-]+_all\.deb' | sort -V | tail -n1)
  
  if [[ -z "$latest_file" ]]; then
    return 1
  fi

  # Verzió kinyerése a fájlnévből (pl. 0.51.71.05-1)
  ver=$(echo "$latest_file" | sed -E 's/nvidia-driver-assistant_(.*)_all\.deb/\1/')
  
  echo "${ver}|${latest_file}"
}

pkgver() {
  cd "${srcdir}/${pkgname}" || return 1

  local meta deb_ver git_hash
  meta="$(_latest_deb_info)" || return 1

  deb_ver="${meta%%|*}"
  # Arch-kompatibilis verziószám (kötőjel helyett alulvonás)
  deb_ver="${deb_ver//-/_}"
  git_hash="$(git rev-parse --short=10 HEAD)"

  printf '%s.g%s' "${deb_ver}" "${git_hash}"
}

prepare() {
  cd "${srcdir}" || return 1

  local meta deb_file deb_url extract_dir data_tar
  extract_dir="${srcdir}/debroot"
  
  meta="$(_latest_deb_info)" || {
    echo "ERROR: Unable to determine latest upstream DEB"
    return 1
  }

  deb_file="${meta#*|}"
  deb_url="${_nvidia_repo_base}/${deb_file}"

  echo "DEBUG: Downloading: ${deb_file}"
  rm -rf "download_tmp" "${extract_dir}"
  mkdir -p "download_tmp" "${extract_dir}"

  curl -fL --retry 5 -o "download_tmp/${deb_file}" "${deb_url}" || return 1

  echo "DEBUG: Unpacking DEB..."
  bsdtar -xf "download_tmp/${deb_file}" -C "${extract_dir}" || return 1

  data_tar=$(find "${extract_dir}" -maxdepth 1 -type f \
    \( -name 'data.tar.xz' -o -name 'data.tar.gz' -o -name 'data.tar.zst' -o -name 'data.tar' \) \
    | head -n 1)

  if [[ -z "${data_tar}" ]]; then
    echo "ERROR: data.tar not found"
    return 1
  fi

  bsdtar -xf "${data_tar}" -C "${extract_dir}" || return 1

  # Script beillesztése a forrásból
  if [[ -f "${srcdir}/${pkgname}/nvidia-driver-assistant" ]]; then
    install -Dm755 "${srcdir}/${pkgname}/nvidia-driver-assistant" \
      "${extract_dir}/usr/bin/nvidia-driver-assistant"
  fi
}

package() {
  cd "${srcdir}/debroot" || return 1

  # Binárisok
  if [[ -f usr/bin/nvidia-driver-assistant ]]; then
    install -Dm755 usr/bin/nvidia-bin/nvidia-driver-assistant \
      "${pkgdir}/usr/bin/nvidia-driver-assistant"
  fi

  # Ha van show-driver a git repóban
  if [[ -f "${srcdir}/${pkgname}/show-driver" ]]; then
    install -Dm755 "${srcdir}/${pkgname}/show-driver" \
      "${pkgdir}/usr/bin/nvidia-recommended-driver"
  fi

  # Adatfájlok másolása (ha léteznek)
  if [[ -d usr/share/${pkgname} ]]; then
    mkdir -p "${pkgdir}/usr/share"
    cp -a usr/share/${pkgname} "${pkgdir}/usr/share/"
  fi

  # Licenc és EULA
  if [[ -f usr/share/doc/${pkgname}/copyright ]]; then
    install -Dm644 usr/share/doc/${pkgname}/copyright \
      "${pkgdir}/usr/share/licenses/${pkgname}/copyright"
  fi

  if [[ -f usr/share/${pkgname}/driver_eula/LICENSE ]]; then
    install -Dm644 usr/share/${pkgname}/driver_eula/LICENSE \
      "${pkgdir}/usr/share/licenses/${pkgname}/NVIDIA-EULA"
  fi
}
