# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=nvidia-driver-assistant
pkgver=0
pkgrel=1
pkgdesc="NVIDIA Driver Assistant for Manjaro, tracking the latest official NVIDIA DEB and using the refactor-branch script"
arch=('any')
url="https://github.com/megvadulthangya/nvidia-driver-assistant"
license=('MIT' 'custom')
depends=('python')
makedepends=('git' 'curl' 'libarchive' 'gzip')

source=("git+https://github.com/megvadulthangya/nvidia-driver-assistant.git#branch=refactor")
sha256sums=('SKIP')

_nvidia_repo_base='https://developer.download.nvidia.com/compute/cuda/repos/ubuntu2404/x86_64'

_fetch_packages_index() {
  local text=""

  if text="$(curl -fsSL "${_nvidia_repo_base}/Packages" 2>/dev/null)"; then
    printf '%s' "${text}"
    return 0
  fi

  if text="$(curl -fsSL "${_nvidia_repo_base}/Packages.gz" 2>/dev/null | gzip -dc 2>/dev/null)"; then
    printf '%s' "${text}"
    return 0
  fi

  return 1
}

_fetch_directory_listing() {
  curl -fsSL "${_nvidia_repo_base}/" 2>/dev/null
}

_latest_deb_info() {
  local meta

  meta="$(
    _fetch_packages_index 2>/dev/null | awk '
      BEGIN { RS=""; FS="\n" }
      /^Package: nvidia-driver-assistant$/ {
        ver=""
        file=""
        for (i = 1; i <= NF; i++) {
          if ($i ~ /^Version: /)  ver  = substr($i, 10)
          if ($i ~ /^Filename: /) file = substr($i, 11)
        }
        if (ver != "" && file != "") {
          print ver "|" file
        }
      }
    ' | sort -t'|' -k1,1V | tail -n1
  )"

  if [[ -n "${meta}" ]]; then
    printf '%s' "${meta}"
    return 0
  fi

  meta="$(
    _fetch_directory_listing 2>/dev/null |
      grep -oE 'nvidia-driver-assistant_[0-9][^"]*_all\.deb' |
      sort -V |
      tail -n1
  )"

  if [[ -n "${meta}" ]]; then
    printf 'unknown|%s' "${meta}"
    return 0
  fi

  return 1
}

pkgver() {
  cd "${srcdir}/${pkgname}" || return 1

  local meta deb_ver git_hash
  meta="$(_latest_deb_info)" || return 1

  deb_ver="${meta%%|*}"
  git_hash="$(git rev-parse --short=10 HEAD)"

  if [[ "${deb_ver}" == "unknown" ]]; then
    printf '0.g%s\n' "${git_hash}"
    return 0
  fi

  printf '%s.g%s\n' "${deb_ver//-/_}" "${git_hash}"
}

prepare() {
  cd "${srcdir}" || return 1

  local meta deb_file deb_url tmpdir extract_dir data_tar

  meta="$(_latest_deb_info)" || {
    echo "ERROR: Nem sikerült meghatározni a legújabb NVIDIA nvidia-driver-assistant DEB-et."
    return 1
  }

  deb_file="${meta#*|}"
  deb_url="${_nvidia_repo_base}/${deb_file}"
  tmpdir="${TMPDIR:-/tmp}/nvidia-driver-assistant-${UID:-0}-$$"
  extract_dir="${srcdir}/debroot"

  echo "Selected DEB: ${deb_file}"
  echo "DEB URL: ${deb_url}"

  rm -rf "${tmpdir}" "${extract_dir}"
  mkdir -p "${tmpdir}" "${extract_dir}"

  curl -fL --retry 5 --retry-delay 2 -o "${tmpdir}/${deb_file}" "${deb_url}" || {
    echo "ERROR: A DEB letöltése nem sikerült."
    return 1
  }

  bsdtar -xf "${tmpdir}/${deb_file}" -C "${extract_dir}" || {
    echo "ERROR: A DEB kicsomagolása nem sikerült."
    return 1
  }

  data_tar="$(find "${extract_dir}" -maxdepth 1 -type f \( -name 'data.tar.xz' -o -name 'data.tar.gz' -o -name 'data.tar.zst' -o -name 'data.tar.bz2' -o -name 'data.tar' \) | head -n 1)"
  [[ -n "${data_tar}" ]] || {
    echo "ERROR: Nem található data.tar.* a DEB-ben."
    return 1
  }

  bsdtar -xf "${data_tar}" -C "${extract_dir}" || {
    echo "ERROR: A data.tar.* kicsomagolása nem sikerült."
    return 1
  }

  rm -f "${extract_dir}"/debian-binary
  rm -f "${extract_dir}"/control.tar.*
  rm -f "${extract_dir}"/data.tar.*

  install -Dm755 "${srcdir}/${pkgname}/nvidia-driver-assistant" \
    "${extract_dir}/usr/bin/nvidia-driver-assistant"
}

package() {
  cd "${srcdir}/debroot" || return 1

  install -Dm755 usr/bin/nvidia-driver-assistant \
    "${pkgdir}/usr/bin/nvidia-driver-assistant"

  if [[ -d usr/share/${pkgname} ]]; then
    mkdir -p "${pkgdir}/usr/share"
    cp -a usr/share/${pkgname} "${pkgdir}/usr/share/"
  fi

  if [[ -d usr/share/doc/${pkgname} ]]; then
    mkdir -p "${pkgdir}/usr/share/doc/${pkgname}"
    shopt -s nullglob dotglob
    for item in usr/share/doc/${pkgname}/*; do
      [[ -f "${item}" ]] || continue
      [[ "$(basename "${item}")" == "copyright" ]] && continue
      install -Dm644 "${item}" \
        "${pkgdir}/usr/share/doc/${pkgname}/$(basename "${item}")"
    done
    shopt -u nullglob dotglob
  fi

  if [[ -f usr/share/doc/${pkgname}/copyright ]]; then
    install -Dm644 usr/share/doc/${pkgname}/copyright \
      "${pkgdir}/usr/share/licenses/${pkgname}/copyright"
  fi

  if [[ -f usr/share/${pkgname}/driver_eula/LICENSE ]]; then
    install -Dm644 usr/share/${pkgname}/driver_eula/LICENSE \
      "${pkgdir}/usr/share/licenses/${pkgname}/NVIDIA-EULA"
  fi

  if [[ -f "${srcdir}/${pkgname}/show-driver" ]]; then
    install -Dm755 "${srcdir}/${pkgname}/show-driver" \
      "${pkgdir}/usr/bin/nvidia-recommended-driver"
  fi
}