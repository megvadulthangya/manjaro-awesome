# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname="stable-diffusion-webui-forge"
pkgname="${_pkgname}-cu124"
pkgver=r8627.dfdcbab6
pkgrel=1
pkgdesc="Stable Diffusion WebUI Forge (Experimental backend: PyTorch 2.4 / CU 12.4)"
arch=('x86_64')
url="https://github.com/lllyasviel/stable-diffusion-webui-forge"
license=('AGPL3')

depends=(
  'python310'
  'git'
  'acl'
)

provides=("${_pkgname}")
conflicts=("${_pkgname}")

makedepends=('git')

install="${pkgname}.install"

source=(
  "${_pkgname}::git+${url}.git#branch=main"
  "${_pkgname}.service"
  "requirements_versions.txt"
)

sha256sums=('SKIP' 'SKIP' 'SKIP')

_appdir="/opt/${_pkgname}"

pkgver() {
  cd "$srcdir/$_pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/$_pkgname"
  cp -v "$srcdir"/requirements_versions.txt .
}

package() {

  # systemd unit (keeps original service file name)
  install -Dm644 "$srcdir/${_pkgname}.service" \
    "$pkgdir/usr/lib/systemd/system/${_pkgname}.service"

  # app files - create main directory with SGID (2775)
  install -d -m 2775 "$pkgdir${_appdir}"
  cp -a "$srcdir/$_pkgname/." "$pkgdir${_appdir}/"
  # Create VAE-taesd directory within models with SGID permissions
  install -d -m 2775 "$pkgdir${_appdir}/models/VAE-taesd"
  
  # make all .sh files executable in the package
  find "$pkgdir${_appdir}" -type f -name "*.sh" -exec chmod +x {} \;

  rm -rf "$pkgdir${_appdir}/.git"
  rm -rf "$pkgdir${_appdir}/.github"
}
