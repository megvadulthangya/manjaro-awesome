# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgbase=nordic-theme-git
pkgname=(
    nordic-theme-git
    nordic-standard-buttons-theme-git
    nordic-darker-theme-git
    nordic-darker-standard-buttons-theme-git
    nordic-bluish-accent-theme-git
    nordic-bluish-accent-standard-buttons-theme-git
)
pkgver=r423.695bd3d
pkgrel=1
pkgdesc="Nord-derived themes for GTK and other platforms (Latest Git HEAD)"
arch=('any')
url="https://github.com/EliverLara/Nordic"
license=('GPL3')
makedepends=('git' 'sassc')

# Különálló források a különböző branchekből
source=(
    "Nordic::git+$url.git#branch=master"
    "Nordic-standard-buttons::git+$url.git#branch=standard-buttons"
    "Nordic-darker::git+$url.git#branch=darker"
    "Nordic-darker-standard-buttons::git+$url.git#branch=darker-standard-buttons"
    "Nordic-bluish-accent::git+$url.git#branch=bluish-accent"
    "Nordic-bluish-accent-standard-buttons::git+$url.git#branch=bluish-accent-standard-buttons"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

# Dinamikus verziószám generálás a master branch alapján
pkgver() {
    cd "$srcdir/Nordic"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

_package() {
    local _reponame="$1"
    local _targetdir="$pkgdir/usr/share/themes/$_reponame"

    # Dinamikus hozzárendelés: az adott alcsomag csak a saját stabil párját helyettesíti és azzal ütközik
    provides=("${pkgname%-git}")
    conflicts=("${pkgname%-git}")

    cd "$srcdir/$_reponame"

    # SCSS fordítás (Nordic paletta érvényesítése)
    if [[ -f gtk-3.0/gtk.scss ]]; then
        sassc -M -t expanded gtk-3.0/gtk.scss gtk-3.0/gtk.css
        sassc -M -t expanded gtk-3.0/gtk-dark.scss gtk-3.0/gtk-dark.css
    fi
    if [[ -f gtk-4.0/gtk.scss ]]; then
        sassc -M -t expanded gtk-4.0/gtk.scss gtk-4.0/gtk.css
        sassc -M -t expanded gtk-4.0/gtk-dark.scss gtk-4.0/gtk-dark.css
    fi
    if [[ -f cinnamon/cinnamon.scss ]]; then
        sassc -M -t expanded cinnamon/cinnamon.scss cinnamon/cinnamon.css
        sassc -M -t expanded cinnamon/cinnamon-dark.scss cinnamon/cinnamon-dark.css
    fi
    if [[ -f gnome-shell/gnome-shell.scss ]]; then
        sassc -M -t expanded gnome-shell/gnome-shell.scss gnome-shell/gnome-shell.css
    fi

    # Telepítés
    install -d "$_targetdir"
    cp -a --no-preserve=ownership . "$_targetdir/"

    # Git fájlok és felesleges dokumentációk takarítása a telepítésből
    rm -rf "$_targetdir/.git" \
           "$_targetdir/.gitignore" \
           "$_targetdir/FUNDING.yml" \
           "$_targetdir/LICENSE" \
           "$_targetdir/README.md" \
           "$_targetdir/Gulpfile.js" \
           "$_targetdir/package.json" \
           "$_targetdir/package-lock.json"

    # Opcionális: korábbi manuális telepítésekből származó .old fájlok törlése
    find "$_targetdir" -type f -name '*.old' -delete
}

package_nordic-theme-git() {
    _package "Nordic"
}

package_nordic-standard-buttons-theme-git() {
    _package "Nordic-standard-buttons"
}

package_nordic-darker-theme-git() {
    _package "Nordic-darker"
}

package_nordic-darker-standard-buttons-theme-git() {
    _package "Nordic-darker-standard-buttons"
}

package_nordic-bluish-accent-theme-git() {
    _package "Nordic-bluish-accent"
}

package_nordic-bluish-accent-standard-buttons-theme-git() {
    _package "Nordic-bluish-accent-standard-buttons"
}
