_pkgsrc="${_pkgname}"
source=(
  "${_pkgsrc}::git+https://git.launchpad.net/compiz"
  # Patchek (11 db)
  "0001-reverse-unity-config.patch"
  "0002-focus-prevention-disable.patch"
