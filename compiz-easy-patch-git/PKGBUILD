_pkgname='compiz'
pkgname="${_pkgname}-easy-patch-git"
pkgver=0.9.14.2.r0.g0000000  # placeholder, a pkgver() felülírja
pkgrel=1
pkgdesc="OpenGL compositing window manager. Includes friendly defaults, GWD theme selector and autostart for Xfce & MATE. Git version."
url="https://launchpad.net/compiz"
arch=('i686' 'x86_64')
license=('GPL-2.0-or-later' 'LGPL-2.1-or-later' 'MIT')

depends=(
