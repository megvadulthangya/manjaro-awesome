# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=capitaine-cursors-nord-git
pkgver=r19.g9b12de9
pkgrel=1
pkgdesc="Capitaine cursor theme with Nord color palette (git version)"
arch=(any)
url="https://github.com/sainnhe/capitaine-cursors"
license=(LGPL3)
source=("${pkgname}::git+${url}.git#branch=master")
provides=('capitaine-cursors-nord')
conflicts=('capitaine-cursors' 'capitaine-cursors-sainnhe-git' 'capitaine-cursors-nord-variant-git')
makedepends=(git libx11 libxcursor libpng nodejs npm yarn typescript chromium python python-pip)
sha256sums=('SKIP')

pkgver() {
  local _repo="${srcdir}/${pkgname}"
  if [[ -d "${_repo}/.git" ]]; then
    printf "r%s.%s" \
      "$(git -C "${_repo}" rev-list --count HEAD)" \
      "$(git -C "${_repo}" rev-parse --short=8 HEAD)"
  else
    return 1
  fi
}

package() {
  local _srcdir="${srcdir}/${pkgname}"
  cd "${_srcdir}"
  install -Ddm755 "${pkgdir}/usr/share/icons"

  ./patch.sh Nord

  cd bitmapper
  yarn install --frozen-lockfile --cache-folder /tmp/yarn-cache

  # Puppeteer konfigurációs fájl létrehozása, hogy a rendszer Chromiumot
  # a szükséges (konténerbarát) argumentumokkal indítsa
  cat > puppeteer.config.cjs << 'EOF'
const path = require('path');

module.exports = {
  executablePath: '/usr/bin/chromium',
  args: [
    '--no-sandbox',
    '--disable-setuid-sandbox',
    '--disable-dev-shm-usage',
    '--disable-gpu',
    '--no-zygote',
    '--single-process',
    '--disable-namespace-sandbox'
  ],
};
EOF

  cd ..

  # Eltávolítjuk a fakeroot LD_PRELOAD-ját
  unset LD_PRELOAD

  make unix
  cp -dr --no-preserve=ownership themes/* "${pkgdir}/usr/share/icons/"
}