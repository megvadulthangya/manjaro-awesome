# Maintainer: Your Name <you@example.com>
pkgname=capitaine-cursors-custom-git
pkgver=r55.b97fd0c
pkgrel=1
pkgdesc="An x-cursor theme inspired by macOS and based on KDE Breeze (custom fork)"
arch=('any')
url="https://github.com/megvadulthangya/capitaine-cursors"
license=('GPL3')
depends=('libxcursor' 'libx11' 'libpng' 'gcc-libs')
makedepends=('git' 'yarn' 'nodejs' 'python' 'python-pip' 'python-clickgen')
provides=("${pkgname%-git}")
conflicts=("${pkgname%-git}")

# Use your fork and the CI branch
_gitname=capitaine-cursors
source=("${_gitname}::git+https://github.com/megvadulthangya/capitaine-cursors.git#branch=CI")
sha256sums=('SKIP')

pkgver() {
  cd "$_gitname"
  git describe --long --tags | sed 's/\([^-]*-g\)/r\1/;s/-/./g'
}

build() {
  cd "$_gitname"

  # Build bitmaps (SVG → PNG)
  cd bitmapper
  yarn install
  yarn render:dark
  yarn render:light
  cd ..

  # Build cursor themes
  cd builder
  python -m pip install --user clickgen
  python build.py
}

package() {
  cd "$_gitname"

  # Install cursor themes
  install -dm755 "$pkgdir/usr/share/icons"
  cp -r themes/* "$pkgdir/usr/share/icons/"
}