# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>
pkgname=capitaine-cursors-nord-git
pkgver=r55.b97fd0c
pkgrel=1
pkgdesc="An x-cursor theme inspired by macOS and based on KDE Breeze (Nord variant, custom fork)"
arch=('any')
url="https://github.com/megvadulthangya/capitaine-cursors"
license=('GPL3')
depends=('libxcursor' 'libx11' 'libpng' 'gcc-libs')
makedepends=(
    'git'
    'yarn'
    'nodejs'
    'python'
    'python-pip'
    'python-clickgen'
    # Chromium/Puppeteer runtime libs for headless build
    'nss'
    'gtk3'
    'libxcomposite'
    'libxdamage'
    'libxrandr'
    'mesa'
    'alsa-lib'
    'at-spi2-core'
    'libdrm'
)
provides=("${pkgname%-git}")
conflicts=("${pkgname%-git}")

_gitname=capitaine-cursors
source=("${_gitname}::git+https://github.com/megvadulthangya/capitaine-cursors.git#branch=CI")
sha256sums=('SKIP')

pkgver() {
  cd "$_gitname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cd "$_gitname"

  # Build bitmaps (SVG → PNG)
  cd bitmapper
  yarn install
  yarn render:dark
  yarn render:light
  cd ..

  # Build cursor themes
  cd builder
  python -m pip install --user clickgen
  python build.py
}

package() {
  cd "$_gitname"

  # Install cursor themes
  install -dm755 "$pkgdir/usr/share/icons"
  cp -r themes/* "$pkgdir/usr/share/icons/"
}