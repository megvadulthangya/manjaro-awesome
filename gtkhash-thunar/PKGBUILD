# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=gtkhash-thunar
pkgver=1.5          # Ezt a pkgver() felülírja a legfrissebb release-szel
pkgrel=1
pkgdesc="A GTK+ utility for computing message digests or checksums (Gtkhash with Thunar filemanager plugin)"
arch=('x86_64')
url="https://github.com/megvadulthangya/gtkhash"
license=('GPL')
depends=(
    'dconf'
    'gtk3'
    'libb2'
    'libgcrypt'
    'nettle'
    'thunar'
)

makedepends=(
    'appstream-glib'
    'curl'          # a GitHub API híváshoz
    'jq'            # a JSON válasz feldolgozásához
    'intltool'
    'librsvg'
    'meson'
    'xdg-utils'
)
provides=(
  gtkhash
  ${pkgname}
)
conflicts=(
  gtkhash 
  gtkhash-caja
  gtkhash-nautilus
  gtkhash-nemo
)

# GitHub által automatikusan generált archívum (minden tag-nél elérhető .tar.gz)
source=("${url}/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('SKIP')    # Dinamikus verzió esetén nem ismerjük előre a hash-t

# A legfrissebb GitHub release tag kiolvasása
pkgver() {
  curl -s "https://api.github.com/repos/megvadulthangya/gtkhash/releases/latest" \
    | jq -r '.tag_name' \
    | sed 's/^v//'
}

prepare() {
  # Az archívumból kicsomagolt könyvtár neve: gtkhash-$pkgver (mert a tag v nélküli verziót ad)
  # Ha a könyvtárnév másképp jönne létre, akkor itt átnevezhetnénk, de GitHub alapértelmezetten
  # 'gtkhash-1.5' lesz a v1.5 tag‑ből, ami pont stimmel.
  mkdir -p plugins
}

build() {
  arch-meson "gtkhash-$pkgver" build \
    -Dglib-checksums='true' \
    -Dlinux-crypto='true' \
    -Dnettle='true' \
    -Dbuild-caja='false' \
    -Dbuild-nautilus='false' \
    -Dbuild-nemo='false' \
    -Dbuild-thunar='true'
  meson compile -C build
}

check() {
  desktop-file-validate build/data/*.desktop
  appstream-util validate-relax --nonet build/data/appdata/*.appdata.xml
  appstream-util validate-relax --nonet build/data/appdata/*.metainfo.xml
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 build/data/appdata/org.gtkhash.thunar.metainfo.xml -t \
    "$pkgdir/usr/share/metainfo/"
}