# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=gtkhash-thunar
pkgver=1.5          # Csak placeholder, a pkgver() felülírja
pkgrel=1
pkgdesc="A GTK+ utility for computing message digests or checksums (Gtkhash with Thunar filemanager plugin)"
arch=('x86_64')
url="https://github.com/megvadulthangya/gtkhash"
license=('GPL')
depends=(
    'dconf'
    'gtk3'
    'libb2'
    'libgcrypt'
    'nettle'
    'thunar'
)
makedepends=(
    'appstream-glib'
    'git'               # a repó klónozásához
    'intltool'
    'librsvg'
    'meson'
    'xdg-utils'
)
provides=(gtkhash ${pkgname})
conflicts=(gtkhash gtkhash-caja gtkhash-nautilus gtkhash-nemo)

# Git forrás – mindig a teljes tárolót klónozza
source=("git+${url}.git")
sha256sums=('SKIP')

# A legfrissebb tag verziószámának kinyerése (v nélkül)
pkgver() {
  cd "$srcdir/gtkhash" 2>/dev/null || exit 1
  # Időben legfrissebb tag, levágva a 'v' előtagot
  git tag --sort=-creatordate 2>/dev/null | head -1 | sed 's/^v//'
}

prepare() {
  cd "$srcdir/gtkhash"
  # Checkout a megfelelő tag-re (a pkgver már frissült)
  local tag="v${pkgver}"
  git checkout "$tag"
  mkdir -p plugins
}

build() {
  cd "$srcdir/gtkhash"
  arch-meson . build \
    -Dglib-checksums='true' \
    -Dlinux-crypto='true' \
    -Dnettle='true' \
    -Dbuild-caja='false' \
    -Dbuild-nautilus='false' \
    -Dbuild-nemo='false' \
    -Dbuild-thunar='true'
  meson compile -C build
}

check() {
  cd "$srcdir/gtkhash"
  desktop-file-validate build/data/*.desktop
  appstream-util validate-relax --nonet build/data/appdata/*.appdata.xml
  appstream-util validate-relax --nonet build/data/appdata/*.metainfo.xml
}

package() {
  cd "$srcdir/gtkhash"
  meson install -C build --destdir "$pkgdir"
  install -Dm644 build/data/appdata/org.gtkhash.thunar.metainfo.xml \
    -t "$pkgdir/usr/share/metainfo/"
}