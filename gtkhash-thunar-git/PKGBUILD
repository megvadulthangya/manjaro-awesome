# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=gtkhash-thunar-git
pkgver=r188.6f2c80a   # példa érték, a pkgver() felülírja
pkgrel=1
pkgdesc='A Thunar filemanager plugin for computing message digests or checksums (development version, nettle4 branch).'
arch=('i686' 'x86_64')
url='https://github.com/megvadulthangya/gtkhash'
license=('GPL2')
makedepends=('git')
depends=('gtkhash-git' 'thunar')
conflicts=("${pkgname%-git}")
provides=("${pkgname%-git}")
source=("gtkhash::git+https://github.com/megvadulthangya/gtkhash.git#branch=nettle4")
md5sums=('SKIP')

pkgver() {
  cd "$srcdir/gtkhash"
  # "headcheck": a verziót a commit számából és a rövid hash-ből képezzük,
  # így minden új push megváltoztatja, és biztosítja a legfrissebb commit beépítését.
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/gtkhash"
  # Biztonsági frissítés a nettle4 branch legfrissebb állapotára
  git fetch origin nettle4
  git checkout nettle4
  git reset --hard origin/nettle4
  echo "HEAD ellenőrzés: $(git log -1 --oneline)"
}

build() {
  cd "$srcdir/gtkhash"
  ./autogen.sh
  ./configure --prefix=/usr --disable-schemas-compile --disable-gtkhash \
              --enable-linux-crypto --enable-nettle --enable-thunar
  make
}

package() {
  # A thunar plugin telepítése (korábban hibásan a nautilus könyvtár volt)
  make -C "$srcdir/gtkhash/src/thunar" DESTDIR="$pkgdir/" install
}
