pkgname=gtkhash-thunar-git
pkgver=r188.6f2c80a  # placeholder, replaced by pkgver()
pkgrel=1
pkgdesc="A GTK+ utility for computing message digests or checksums (Gtkhash with Thunar plugin, git version from nettle4 branch)"
arch=('x86_64')
url="https://github.com/megvadulthangya/gtkhash"
license=('GPL')
depends=(
    'dconf'
    'gtk3'
    'libb2'
    'libgcrypt'
    'nettle'
    'thunar'
)
makedepends=(
    'appstream-glib'
    'git'
    'intltool'
    'librsvg'
    'meson'
    'xdg-utils'
)
provides=("${pkgname%-git}" 'gtkhash')
conflicts=("${pkgname%-git}" 'gtkhash' 'gtkhash-caja' 'gtkhash-nautilus' 'gtkhash-nemo')
source=("gtkhash::git+https://github.com/megvadulthangya/gtkhash.git#branch=nettle4")
md5sums=('SKIP')

pkgver() {
  cd "$srcdir/gtkhash"
  # headcheck: version from commit count and short hash ensures rebuild on every push
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/gtkhash"
  # Ensure we are on the latest nettle4 branch
  git fetch origin nettle4
  git checkout nettle4
  git reset --hard origin/nettle4
}

build() {
  arch-meson "$srcdir/gtkhash" build \
    -Dglib-checksums='true' \
    -Dlinux-crypto='true' \
    -Dnettle='true' \
    -Dbuild-caja='false' \
    -Dbuild-nautilus='false' \
    -Dbuild-nemo='false' \
    -Dbuild-thunar='true'
  meson compile -C build
}

check() {
  desktop-file-validate build/data/*.desktop
  appstream-util validate-relax --nonet build/data/appdata/*.appdata.xml
  appstream-util validate-relax --nonet build/data/appdata/*.metainfo.xml
}

package() {
  meson install -C build --destdir "$pkgdir"
  install -Dm644 "$srcdir/gtkhash/data/appdata/org.gtkhash.thunar.metainfo.xml" -t \
    "$pkgdir/usr/share/metainfo/"
}