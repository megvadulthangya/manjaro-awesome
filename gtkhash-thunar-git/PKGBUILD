# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>
# Contributor: Sam Burgos <santiago.burgos1089 at gmail dot com>
# Contributor: carstene1ns <arch carsten-teibes de>

pkgname=gtkhash-thunar-git
pkgver=r1050.4bbc464
pkgrel=1
pkgdesc="A GTK+ utility for computing message digests or checksums (Gtkhash with Thunar plugin, git version hybrid GTK3-GTK4 Code)"
arch=('x86_64')
url="https://github.com/megvadulthangya/gtkhash"
license=('GPL')
depends=(
    'dconf'
    'gtk3'
    'libb2'
    'libgcrypt'
    'nettle'
    'mbedtls'
    'thunar'
)
makedepends=(
    'appstream-glib'
    'git'
    'intltool'
    'librsvg'
    'meson'
    'xdg-utils'
    'mbedtls'
)
provides=("${pkgname%-git}" 'gtkhash')
conflicts=("${pkgname%-git}" 'gtkhash' 'gtkhash-caja' 'gtkhash-nautilus' 'gtkhash-nemo')
source=("gtkhash::git+https://github.com/megvadulthangya/gtkhash.git#branch=extensions")
md5sums=('SKIP')

pkgver() {
  cd "$srcdir/gtkhash"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/gtkhash"
  git fetch origin extensions
  git checkout extensions
  git reset --hard origin/extensions
}

build() {
  arch-meson "$srcdir/gtkhash" build \
    -Dglib-checksums=true \
    -Dlinux-crypto=true \
    -Dnettle=true \
    -Dmbedtls=true \
    -Dlibcrypto=true \
    -Dbuild-caja=false \
    -Dbuild-nautilus=false \
    -Dbuild-nemo=false \
    -Dbuild-thunar=true
  meson compile -C build
}

check() {
  desktop-file-validate build/data/*.desktop
  appstream-util validate-relax --nonet build/data/appdata/*.appdata.xml
  appstream-util validate-relax --nonet build/data/appdata/*.metainfo.xml
}

package() {
  meson install -C build --destdir "$pkgdir"
}
