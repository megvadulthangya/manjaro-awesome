# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname=awesome
pkgname=${_pkgname}-git
pkgver=4.3.1732.gf1388f9fc
pkgrel=3
pkgdesc='Highly configurable framework window manager'
arch=('i686' 'x86_64')
url='https://awesomewm.org/'
license=('GPL2')

depends=(
  'cairo' 'dbus' 'gdk-pixbuf2' 'libxdg-basedir'
  'libxkbcommon-x11' 'lua54' 'lua54-lgi' 'pango'
  'startup-notification' 'xcb-util-cursor'
  'xcb-util-keysyms' 'xcb-util-wm' 'xcb-util-xrm'
  'libxfixes'
)

makedepends=(
  'asciidoctor' 'cmake' 'docbook-xsl' 'git'
  'imagemagick' 'xmlto'
  'lua54' 'lua54-luarocks'
)

optdepends=(
  'rlwrap: readline support for awesome-client'
  'dex: autostart your desktop files'
  'xcb-util-errors: for pretty-printing of X11 errors'
  'librsvg: for displaying SVG files without scaling artifacts'
)

provides=('notification-daemon' 'awesome')
conflicts=('awesome')

source=("$pkgname::git+https://github.com/awesomeWM/awesome.git")
md5sums=('SKIP')

_LUA_VER=5.4

pkgver() {
  cd "$pkgname"
  git describe | sed 's/^v//;s/-/./g'
}

build() {
  cd "$srcdir/$pkgname"

  # 🔥 LOCAL LUAROCKS ENV (Lua 5.4)
  export LUAROCKS_CONFIG="$srcdir/luarocks-config.lua"

  cat > "$LUAROCKS_CONFIG" <<EOF
lua_version = "5.4"
lua_interpreter = "lua5.4"
variables = {
  LUA = "/usr/bin/lua5.4",
  LUA_INCDIR = "/usr/include/lua5.4",
  LUA_LIBDIR = "/usr/lib"
}
EOF

  # 🔥 Install ldoc LOCAL (nem system!)
  luarocks --lua-version=5.4 --tree="$srcdir/luarocks" install ldoc

  export PATH="$srcdir/luarocks/bin:$PATH"

  mkdir -p build
  cd build

  cmake .. \
    -DCMAKE_BUILD_TYPE=RELEASE \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DSYSCONFDIR=/etc \
    -DLUA_INCLUDE_DIR=/usr/include/lua${_LUA_VER} \
    -DLUA_LIBRARY=/usr/lib/liblua.so.${_LUA_VER} \
    -DLUA_EXECUTABLE=/usr/bin/lua${_LUA_VER} \
    -DWITH_DOC=ON \
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5

  make
}

package() {
  cd "$srcdir/$pkgname/build"

  make DESTDIR="$pkgdir" install

  install -Dm644 "$srcdir/$pkgname/awesome.desktop" \
    "$pkgdir/usr/share/xsessions/awesome.desktop"

  rm -f "$pkgdir/etc/xdg/awesome/rc.lua"
}
