# Maintainer: G Shoots

pkgbase=awesome-git
pkgname=('awesome53-git' 'awesome54-git')
pkgver=4.3.1732.gf1388f9fc
pkgrel=1
pkgdesc='Highly configurable framework window manager (git)'
arch=('x86_64')
url='https://awesomewm.org/'
license=('GPL2')

source=("awesome::git+https://github.com/awesomeWM/awesome.git")
md5sums=('SKIP')

makedepends=(
  'asciidoctor'
  'cmake'
  'docbook-xsl'
  'git'
  'imagemagick'
  'luarocks'
  'xmlto'

  # LUA 5.3
  'lua53'
  'lua53-lgi'
  'lua53-penlight'

  # LUA 5.4
  'lua54'
  'lua54-lgi'
  'lua54-penlight'
)

pkgver() {
  cd "$srcdir/awesome"
  git describe --long --tags | sed 's/^v//;s/-/./g'
}

build() {
  cd "$srcdir"

  # --- LUA 5.3 ---
  mkdir -p build-lua53 rocks-lua53
  luarocks --lua-version=5.3 --tree="$srcdir/rocks-lua53" install ldoc --deps-mode=none

  export PATH="$srcdir/rocks-lua53/bin:$PATH"

  cmake -S awesome -B build-lua53 \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DSYSCONFDIR=/etc \
    -DLUA_INCLUDE_DIR=/usr/include/lua5.3 \
    -DLUA_LIBRARY=/usr/lib/liblua.so.5.3 \
    -DLUA_EXECUTABLE=/usr/bin/lua5.3 \
    -DLDOC_EXECUTABLE="$srcdir/rocks-lua53/bin/ldoc"

  cmake --build build-lua53

  # --- LUA 5.4 ---
  mkdir -p build-lua54 rocks-lua54
  luarocks --lua-version=5.4 --tree="$srcdir/rocks-lua54" install ldoc --deps-mode=none

  export PATH="$srcdir/rocks-lua54/bin:$PATH"

  cmake -S awesome -B build-lua54 \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DSYSCONFDIR=/etc \
    -DLUA_INCLUDE_DIR=/usr/include/lua5.4 \
    -DLUA_LIBRARY=/usr/lib/liblua.so.5.4 \
    -DLUA_EXECUTABLE=/usr/bin/lua5.4 \
    -DLDOC_EXECUTABLE="$srcdir/rocks-lua54/bin/ldoc"

  cmake --build build-lua54
}

_common_package() {
  make -C "$1" DESTDIR="$pkgdir" install

  install -Dm644 "$srcdir/awesome/awesome.desktop" \
    "$pkgdir/usr/share/xsessions/awesome.desktop"

  rm -f "$pkgdir/etc/xdg/awesome/rc.lua"
}

package_awesome53-git() {
  depends=(
    cairo dbus gdk-pixbuf2 libxdg-basedir libxkbcommon-x11
    lua53 lua53-lgi
    pango startup-notification
    xcb-util-cursor xcb-util-keysyms xcb-util-wm xcb-util-xrm
    libxfixes
  )

  provides=('awesome' 'notification-daemon')
  conflicts=('awesome' 'awesome54-git')

  _common_package "$srcdir/build-lua53"
}

package_awesome54-git() {
  depends=(
    cairo dbus gdk-pixbuf2 libxdg-basedir libxkbcommon-x11
    lua54 lua54-lgi
    pango startup-notification
    xcb-util-cursor xcb-util-keysyms xcb-util-wm xcb-util-xrm
    libxfixes
  )

  provides=('awesome' 'notification-daemon')
  conflicts=('awesome' 'awesome53-git')

  _common_package "$srcdir/build-lua54"
}
