# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname=awesome
pkgname=${_pkgname}-git
pkgver=4.3.1732.gf1388f9fc
pkgrel=2
pkgdesc='Highly configurable framework window manager'
arch=('i686' 'x86_64')
url='https://awesomewm.org/'
license=('GPL2')

depends=('cairo' 'dbus' 'gdk-pixbuf2' 'libxdg-basedir' 'libxkbcommon-x11'
         'lua54' 'lua54-lgi' 'pango' 'startup-notification' 'xcb-util-cursor'
         'xcb-util-keysyms' 'xcb-util-wm' 'xcb-util-xrm' 'libxfixes'
         'awesome-copycats-manjaro')

makedepends=('asciidoctor' 'cmake' 'docbook-xsl' 'git' 'imagemagick'
             'lua54-luarocks' 'lua54-lpeg' 'lua54-penlight' 'xmlto')

optdepends=('rlwrap: readline support for awesome-client'
            'dex: autostart your desktop files'
            'xcb-util-errors: for pretty-printing of X11 errors'
            'librsvg: for displaying SVG files without scaling artifacts')

provides=('notification-daemon' 'awesome')
conflicts=('awesome')

source=("$pkgname::git+https://github.com/awesomeWM/awesome.git")
md5sums=('SKIP')

_LUA_VER=5.4

pkgver() {
  cd "$pkgname"
  git describe | sed 's/^v//;s/-/./g'
}

build() {
  local builddir="$srcdir/build"
  local rocks_tree="$srcdir/luarocks-tree"

  mkdir -p "$builddir" "$rocks_tree"

  # Build a Lua 5.4-compatible ldoc in a private tree.
  # This keeps the documentation generator aligned with the awesome build.
  luarocks --lua-version="${_LUA_VER}" --tree "$rocks_tree" install markdown --deps-mode=none
  luarocks --lua-version="${_LUA_VER}" --tree "$rocks_tree" install ldoc --deps-mode=none

  cd "$builddir"
  cmake "$srcdir/$pkgname" \
    -DCMAKE_BUILD_TYPE=RELEASE \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DSYSCONFDIR=/etc \
    -DLUA_INCLUDE_DIR=/usr/include/lua${_LUA_VER} \
    -DLUA_LIBRARY=/usr/lib/liblua.so.${_LUA_VER} \
    -DLUA_EXECUTABLE=/usr/bin/lua${_LUA_VER} \
    -DLDOC_EXECUTABLE="$rocks_tree/bin/ldoc" \
    -DGENERATE_DOC=ON \
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5
  make
}

package() {
  cd "$srcdir/build"
  make DESTDIR="$pkgdir" install

  install -Dm644 "$srcdir/$pkgname/awesome.desktop" \
    "$pkgdir/usr/share/xsessions/awesome.desktop"

  rm -f "$pkgdir/etc/xdg/awesome/rc.lua"
}
