# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=gtkhash-caja-git
pkgver=r1054.729d4d0
pkgrel=1
pkgdesc="A GTK+ utility for computing message digests or checksums (Gtkhash with Caja plugin, git version)"
arch=('x86_64')
url="https://github.com/megvadulthangya/gtkhash"
license=('GPL')
depends=(
    'dconf'
    'gtk3'
    'libb2'
    'libgcrypt'
    'nettle'
    'mbedtls'
    'caja'                     # Caja fájlkezelő (tartalmazza a fejlesztői header-eket is)
)
makedepends=(
    'appstream-glib'
    'git'
    'intltool'
    'librsvg'
    'meson'
    'xdg-utils'
    'mbedtls'
    'caja'                     # build-időben is kell a fejlécek miatt
)
provides=("${pkgname%-git}" 'gtkhash')
conflicts=(
    "${pkgname%-git}"
    'gtkhash'
    'gtkhash-nemo'
    'gtkhash-nautilus'
    'gtkhash-thunar-git'
    'gtkhash-caja'             # ha létezik stabil verzió
)
source=("gtkhash::git+https://github.com/megvadulthangya/gtkhash.git#branch=extensions")
md5sums=('SKIP')

pkgver() {
  cd "$srcdir/gtkhash"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/gtkhash"
  git fetch origin extensions
  git checkout extensions
  git reset --hard origin/extensions
}

build() {
  arch-meson "$srcdir/gtkhash" build \
    -Dglib-checksums=true \
    -Dlinux-crypto=true \
    -Dnettle=true \
    -Dmbedtls=true \
    -Dlibcrypto=true \
    -Dbuild-caja=true \
    -Dbuild-nautilus=false \
    -Dbuild-nemo=false \
    -Dbuild-thunar=false
  meson compile -C build
}

check() {
  desktop-file-validate build/data/*.desktop
  appstream-util validate-relax --nonet build/data/appdata/*.appdata.xml
  appstream-util validate-relax --nonet build/data/appdata/*.metainfo.xml
}

package() {
  meson install -C build --destdir "$pkgdir"
}
