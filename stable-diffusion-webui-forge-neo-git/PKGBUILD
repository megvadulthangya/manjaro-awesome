# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname="stable-diffusion-webui-forge-neo"
pkgname="${_pkgname}-git"
pkgver=r9385.28e39472
pkgrel=1
pkgdesc="Stable Diffusion WebUI Forge Neo (Experimental fork, PyTorch 2.6 / CUDA 12.6)"
arch=('x86_64')
url="https://github.com/Haoming02/sd-webui-forge-classic"
license=('AGPL3')

depends=(
  'python313'
  'git'
  'acl'
)

provides=("stable-diffusion-webui-forge")
conflicts=("stable-diffusion-webui-forge")

makedepends=('git')

install="${pkgname}.install"

source=(
  "${_pkgname}::git+${url}.git#branch=neo"
  "stable-diffusion-webui-forge.service"
)

sha256sums=('SKIP' 'SKIP')

_appdir="/opt/stable-diffusion-webui-forge"

pkgver() {
  cd "$srcdir/$_pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/$_pkgname"

  msg "Patching webui-user.sh for CUDA 12.6 (PyTorch 2.6)..."

  # Replace the TORCH_COMMAND line with the correct version and add TORCH_INDEX_URL
  sed -i \
    -e 's|^export TORCH_COMMAND=.*|export TORCH_COMMAND="pip install torch==2.6.0+cu126 torchvision==0.21.0+cu126 --extra-index-url https://download.pytorch.org/whl/cu126"|' \
    webui-user.sh

  # Insert TORCH_INDEX_URL before TORCH_COMMAND if not already present
  if ! grep -q 'TORCH_INDEX_URL' webui-user.sh; then
    sed -i '/^export TORCH_COMMAND=/i export TORCH_INDEX_URL="https://download.pytorch.org/whl/cu126"' webui-user.sh
  fi

  # Keep --uv and other settings; ensure COMMANDLINE_ARGS="--uv" remains
  # (the original file already has it, so no change needed)
}

package() {
  # Install systemd service file
  install -Dm644 "$srcdir/stable-diffusion-webui-forge.service" \
    "$pkgdir/usr/lib/systemd/system/stable-diffusion-webui-forge.service"

  # Copy application files with SGID directory
  install -d -m 2775 "$pkgdir${_appdir}"
  cp -a "$srcdir/$_pkgname/." "$pkgdir${_appdir}/"

  # Optional VAE-taesd directory
  install -d -m 2775 "$pkgdir${_appdir}/models/VAE-taesd"

  # Normalize permissions explicitly after copy
  find "$pkgdir${_appdir}" -type d -exec chmod 755 {} \;
  find "$pkgdir${_appdir}" -type f -exec chmod 644 {} \;
  find "$pkgdir${_appdir}" -type f -name "*.sh" -exec chmod 755 {} \;

  # Remove developer files
  rm -rf "$pkgdir${_appdir}/.git"
  rm -rf "$pkgdir${_appdir}/.github"
}