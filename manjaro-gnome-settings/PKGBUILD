pkgname=(
  'manjaro-gnome-settings'
  'manjaro-gnome-extension-settings'
)
pkgbase=manjaro-gnome-settings
pkgver=20260717
pkgrel=1
arch=('any')
url="https://github.com/megvadulthangya/manjaro-gnome-settings"
license=('GPL-3.0-or-later')
makedepends=('git')
# A fork aktuális állapotát használjuk, branch=nord
source=("git+https://github.com/megvadulthangya/manjaro-gnome-settings.git#branch=nord")
sha256sums=('SKIP')

pkgver() {
  cd "${pkgbase}"
  git show -s --format=%cd --date=format:%Y%m%d HEAD
}

package_manjaro-gnome-settings() {
  pkgdesc="Manjaro Linux GNOME settings"
  depends=(
    'accent-color-change'
    'nordic-standard-buttons-theme-git'
    'nordzy-icon-theme'
    'capitaine-cursors-nord-git'
    'manjaro-base-skel'
    'ttf-firacode-nerd'
  )
  optdepends=(
    'qt5ct: Qt 5 theming'
    'qt6ct: Qt 6 theming'
  )
  provides=('manjaro-desktop-settings')
  conflicts=(
    'manjaro-gnome-settings-gnome-next'
    'manjaro-gnome-settings-19.0'
    'manjaro-gnome-assets'
    'manjaro-gdm-theme'
    'firefox-gnome-theme-maia'
    'adwaita-maia'
    'manjaro-gdm-branding'
  )
  replaces=(
    'manjaro-gnome-settings-gnome-next'
    'manjaro-gnome-assets'
    'manjaro-gdm-branding'
  )
  install='settings.install'

  cd "${pkgbase}"

  # Schemas
  install -Dm644 schemas/99_manjaro-settings.gschema.override -t \
    "${pkgdir}"/usr/share/glib-2.0/schemas/

  # Dconf
  install -Dm644 dconf/profile/user -t "${pkgdir}"/etc/dconf/profile/
  install -Dm644 dconf/db/local.d/00_app_folder_defaults -t \
    "${pkgdir}"/etc/dconf/db/local.d/

  # Kvantum
  install -Dm644 xdg/Kvantum/kvantum.kvconfig -t "${pkgdir}/etc/xdg/Kvantum/"

  # Systemd
  install -Dm644 systemd/logind.conf.d/21-kill-user-processes.conf -t \
    "${pkgdir}/etc/systemd/logind.conf.d/"

  # User defaults
  cp -r profile.d skel "${pkgdir}"/etc/

  # Qt5Ct / Qt6Ct color schemes (Nord)
#   install -Dm644 colors/Adwaita-nord.conf -t \
#    "${pkgdir}"/usr/share/qt5ct/colors/
#  install -Dm644 colors/Adwaita-nord-dark.conf -t \
#    "${pkgdir}"/usr/share/qt5ct/colors/
#  install -Dm644 colors/Adwaita-nord.conf -t \
#    "${pkgdir}"/usr/share/qt6ct/colors/
#  install -Dm644 colors/Adwaita-nord-dark.conf -t \
#    "${pkgdir}"/usr/share/qt6ct/colors/

  # GTK4 symlinks to Nordic-standard-buttons theme
  mkdir -p "${pkgdir}/etc/skel/.config/gtk-4.0"
#  ln -s /usr/share/themes/Nordic-standard-buttons/assets \
#    "${pkgdir}/etc/skel/.config/gtk-4.0/assets"
  ln -s /usr/share/themes/Nordic-standard-buttons/gtk-4.0/gtk.css \
    "${pkgdir}/etc/skel/.config/gtk-4.0/gtk.css"
  ln -s /usr/share/themes/Nordic-standard-buttons/gtk-4.0/gtk-dark.css \
    "${pkgdir}/etc/skel/.config/gtk-4.0/gtk-dark.css"
}

package_manjaro-gnome-extension-settings() {
  pkgdesc="Manjaro Linux GNOME extensions settings"
  depends=(
    'gnome-shell-extensions'
    'manjaro-gnome-settings'
  )
  optdepends=(
    'gnome-browser-connector: browser connecter for extensions website'
  )
  conflicts=(
    'gnome-shell-extension-custom-accent-colors'
    'manjaro-gnome-extension-settings-gnome-next'
  )
  replaces=(
    'manjaro-gnome-extension-settings-gnome-next'
  )

  cd "${pkgbase}"

  schemas=(
    org.gnome.shell.extensions.arcmenu
    org.gnome.shell.extensions.custom-accent-colors
    org.gnome.shell.extensions.dash-to-dock
    org.gnome.shell.extensions.dash-to-panel
    org.gnome.shell.extensions.gnome-ui-tune
    org.gnome.shell.extensions.user-theme
  )

  for schema in ${schemas[*]}; do
    install -Dm644 schemas/${schema}.gschema.override -t \
      "${pkgdir}"/usr/share/glib-2.0/schemas/
  done
}
