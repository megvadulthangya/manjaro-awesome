[Unit]
Description=Stable Diffusion WebUI Forge (python310)
After=network.target

[Service]
Type=simple
User=sdwebui-forge
Group=sdwebui-forge
WorkingDirectory=/opt/stable-diffusion-webui-forge

Environment=PYTHONUNBUFFERED=1

ExecStart=/bin/bash -lc '\
  set -a; \
  source /opt/stable-diffusion-webui-forge/webui-user.sh; \
  set +a; \
  : "${DATA_DIR:=/var/opt/stable-diffusion-webui-forge/data}"; \
  mkdir -p "$DATA_DIR"; \
  exec /opt/stable-diffusion-webui-forge/venv/bin/python \
    /opt/stable-diffusion-webui-forge/launch.py \
    --data-dir "$DATA_DIR" \
'

Restart=always
StartLimitIntervalSec=120
StartLimitBurst=15
UMask=007

[Install]
WantedBy=multi-user.target
