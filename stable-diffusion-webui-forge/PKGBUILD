# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname="stable-diffusion-webui-forge"
pkgname="${_pkgname}"
pkgver=r8627.dfdcbab6
pkgrel=1
pkgdesc="Stable Diffusion WebUI Forge (main branch) - python310 runtime"
arch=('x86_64')
url="https://github.com/lllyasviel/stable-diffusion-webui-forge"
license=('AGPL3')

depends=(
  'python310'
  'git'
  'acl'
)

makedepends=('git')

install="${pkgname}.install"

source=(
  "${pkgname}::git+${url}.git#branch=main"
  "${pkgname}.service"
)

sha256sums=('SKIP' 'SKIP')

_appdir="/opt/${_pkgname}"

pkgver() {
  cd "$srcdir/$pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {

  # systemd unit
  install -Dm644 "$srcdir/${pkgname}.service" \
    "$pkgdir/usr/lib/systemd/system/${pkgname}.service"

  # app files - SGID bittel hozzuk létre a főkönyvtárat (2775)
  install -d -m 2775 "$pkgdir${_appdir}"
  cp -a "$srcdir/$pkgname/." "$pkgdir${_appdir}/"
  
  # --- INJEKCIÓ: requirements_versions.txt módosítása ---
  # Hozzáadjuk a hiányzó csomagokat, hogy a Forge saját telepítője felismerje őket
  echo "joblib" >> "$pkgdir${_appdir}/requirements_versions.txt"
  echo "insightface" >> "$pkgdir${_appdir}/requirements_versions.txt"
  
  # Kényszerítjük a biztonságos verziókat a fájlban (felülírjuk ha már benne van)
  sed -i 's/numpy==.*/numpy==1.26.2/' "$pkgdir${_appdir}/requirements_versions.txt"
  sed -i 's/protobuf==.*/protobuf==3.20.0/' "$pkgdir${_appdir}/requirements_versions.txt"
  # ------------------------------------------------------
  
  # .sh fájlok futtathatóvá tétele már a csomagban
  find "$pkgdir${_appdir}" -type f -name "*.sh" -exec chmod +x {} \;

  rm -rf "$pkgdir${_appdir}/.git"
  # Esetleg a .github mappát is törölheted, ha nincs rá szükség, ahogy a kohya-nál:
  rm -rf "$pkgdir${_appdir}/.github"

}
