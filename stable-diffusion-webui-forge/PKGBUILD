# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=stable-diffusion-webui-forge
pkgver=r0.0000000
pkgrel=1
pkgdesc="Stable Diffusion WebUI Forge (system-wide install for Manjaro ISO)"
arch=('x86_64')
url="https://github.com/lllyasviel/stable-diffusion-webui-forge"
license=('MIT')
depends=('python310')
backup=('opt/stable-diffusion-webui-forge/webui-user.sh')
source=(
  "stable-diffusion-webui-forge::git+https://github.com/lllyasviel/stable-diffusion-webui-forge.git#tag=v${pkgver}"
  "stable-diffusion-webui-forge.service"
)
sha256sums=('SKIP' 'SKIP')

install="${pkgname}.install"

package() {
  install -dm755 "${pkgdir}/opt"
  cp -r "${srcdir}/stable-diffusion-webui-forge" \
        "${pkgdir}/opt/stable-diffusion-webui-forge"

  # model mappa (üresen, hogy ne törlődjön frissítéskor)
  install -dm2775 "${pkgdir}/opt/stable-diffusion-webui-forge/models"

  # service
  install -Dm644 "${srcdir}/stable-diffusion-webui-forge.service" \
    "${pkgdir}/usr/lib/systemd/system/stable-diffusion-webui-forge.service"
}
