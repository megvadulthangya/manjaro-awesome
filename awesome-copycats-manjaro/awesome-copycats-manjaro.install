pre_install() {
    # Ha már létezik az rc.lua, de nem a pacman kezeli, mentsük el
    if [ -f "/etc/xdg/awesome/rc.lua" ]; then
        echo "==> Figyelem: Létező rc.lua észlelve. Mentés: rc.lua.og"
        mv "/etc/xdg/awesome/rc.lua" "/etc/xdg/awesome/rc.lua.og"
    fi
}

pre_upgrade() {
    pre_install
}
