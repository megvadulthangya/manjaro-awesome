# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=awesome-copycats-manjaro
pkgver=1064
pkgrel=1
pkgdesc="Nord themed AwesomeWM configuration based on awesome-copycats"
arch=('any')
url="https://github.com/megvadulthangya/awesome-copycats-manjaro"
license=('GPL3')

depends=('awesome')
makedepends=('git')

source=("$pkgname-$pkgver.tar.gz::https://github.com/megvadulthangya/awesome-copycats-manjaro/archive/refs/heads/nord.tar.gz")
sha256sums=('SKIP')

package() {

  cd "$srcdir/awesome-copycats-manjaro-nord"

  # Target directory
  install -dm755 "$pkgdir/etc/skel/.config/awesome"

  # Copy configuration files
  cp -a . "$pkgdir/etc/skel/.config/awesome/"

  # Remove unwanted repository metadata
  rm -rf "$pkgdir/etc/skel/.config/awesome/.git"
  rm -rf "$pkgdir/etc/skel/.config/awesome/.github" 2>/dev/null || true
  rm -f "$pkgdir/etc/skel/.config/awesome/.gitignore"

  # Rename template if present
  if [[ -f "$pkgdir/etc/skel/.config/awesome/rc.lua.template" ]]; then
      mv "$pkgdir/etc/skel/.config/awesome/rc.lua.template" \
         "$pkgdir/etc/skel/.config/awesome/rc.lua"
  fi

  # Ensure correct permissions
  find "$pkgdir/etc/skel/.config/awesome" -type f -exec chmod 644 {} \;
  find "$pkgdir/etc/skel/.config/awesome" -type d -exec chmod 755 {} \;

  # Install helper script
  install -dm755 "$pkgdir/usr/share/$pkgname"

  cat > "$pkgdir/usr/share/$pkgname/install-to-user.sh" << 'EOF'
#!/bin/bash

set -e

CONFIG_DIR="$HOME/.config/awesome"
SOURCE_DIR="/etc/skel/.config/awesome"

if [[ -d "$CONFIG_DIR" ]]; then
    echo "Backing up existing Awesome config to $CONFIG_DIR.backup"
    mv "$CONFIG_DIR" "$CONFIG_DIR.backup"
fi

echo "Installing Awesome WM Nord configuration..."
cp -r "$SOURCE_DIR" "$HOME/.config/"

echo "Installation complete."
echo "Restart Awesome WM with Mod+Ctrl+R"
EOF

  chmod +x "$pkgdir/usr/share/$pkgname/install-to-user.sh"

  # Install README
  install -dm755 "$pkgdir/usr/share/doc/$pkgname"

  cat > "$pkgdir/usr/share/doc/$pkgname/README" << EOF
Awesome WM Nord Configuration

To install the configuration for your user run:

/usr/share/$pkgname/install-to-user.sh

This will copy the configuration from /etc/skel/.config/awesome
to your home directory.
EOF

}
