# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=awesome-copycats-manjaro
pkgver=r1065.a88dedf
pkgrel=2
pkgdesc="Nord themed AwesomeWM configuration (System-wide installation)"
arch=('any')
url="https://github.com/megvadulthangya/awesome-copycats-manjaro"
license=('GPL3')

depends=('awesome')
makedepends=('git')

# A pacman kezelje a konfigurációs fájl felülírást/mentést
backup=('etc/xdg/awesome/rc.lua')

source=("$pkgname::git+https://github.com/megvadulthangya/awesome-copycats-manjaro.git#branch=nord")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$pkgname"
  printf "r%s.%s" \
    "$(git rev-list --count HEAD)" \
    "$(git rev-parse --short HEAD)"
}

package() {
  cd "$srcdir/$pkgname"

  # Célkönyvtárak létrehozása
  install -dm755 "$pkgdir/etc/xdg/awesome"
  install -dm755 "$pkgdir/usr/share/awesome"

  # 1. Konfigurációs mappák másolása az /etc/xdg/awesome/ alá
  for dir in configuration modules signals widgets; do
    if [[ -d "$dir" ]]; then
      cp -r "$dir" "$pkgdir/etc/xdg/awesome/"
    fi
  done

  # 2. Themes mappa másolása az /usr/share/awesome/ alá
  if [[ -d "themes" ]]; then
    cp -r themes "$pkgdir/usr/share/awesome/"
  fi

  # 3. rc.lua kezelése
  # Az eredeti rc.lua-ról nem tudunk "biztonsági mentést" csinálni a csomagon belül, 
  # de a template-et beállítjuk rc.lua-nak és megőrizzük template-ként is.
  if [[ -f rc.lua.template ]]; then
    # Telepítés mint rc.lua
    install -m644 rc.lua.template "$pkgdir/etc/xdg/awesome/rc.lua"
    # Telepítés mint rc.lua.template
    install -m644 rc.lua.template "$pkgdir/etc/xdg/awesome/rc.lua.template"
  fi

  # Jogosultságok tisztázása
  find "$pkgdir/etc/xdg/awesome" -type d -exec chmod 755 {} \;
  find "$pkgdir/etc/xdg/awesome" -type f -exec chmod 644 {} \;
  find "$pkgdir/usr/share/awesome/themes" -type d -exec chmod 755 {} \;
  find "$pkgdir/usr/share/awesome/themes" -type f -exec chmod 644 {} \;

  # README (opcionális, de a standard része)
  if [[ -f README.rst ]]; then
    install -Dm644 README.rst "$pkgdir/usr/share/doc/$pkgname/README.rst"
  fi
}
