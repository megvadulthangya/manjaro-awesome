# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>
# upstream: Luca CPZ <luca.cpz [at] gmail [dot] com>
# Modified for local build with automatic versioning

_pkgname=lain
pkgname=$_pkgname-git
pkgver=r1797.88f5a8a
pkgrel=1
epoch=1
pkgdesc="Layouts, asynchronous widgets and utilities for Awesome WM"
arch=("any")
url="https://github.com/lcpz/$_pkgname"
license=("GPL2")
depends=("awesome")
makedepends=("git")
optdepends=("curl: for IMAP, MPD and weather widgets")
provides=("$_pkgname")
conflicts=("$_pkgname")
# SKIP checksum for CI/CD compatibility
sha256sums=("SKIP")
# Use direct GitHub URL - NO AUR CAPTCHA!
source=("git+https://github.com/lcpz/lain.git")

pkgver() {
    cd "$_pkgname"
    printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
    cd "$_pkgname"
    
    # Célkönyvtár meghatározása az Awesome WM struktúrában
    local _dest="$pkgdir/usr/share/awesome/lib/$_pkgname"
    
    # Telepítési könyvtár létrehozása
    install -dm755 "$_dest"
    
    # Teljes forrás másolása a célhelyre
    cp -ra . "$_dest/"
    
    # Takarítás: git metaadatok eltávolítása a csomagból
    rm -rf "$_dest/.git"
    rm -f "$_dest/.gitignore"
}
