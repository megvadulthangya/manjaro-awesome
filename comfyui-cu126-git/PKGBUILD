# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname="ComfyUI"
pkgname="comfyui-cu126-git"
pkgver=r5054.e75f775a
pkgrel=1
pkgdesc="ComfyUI GUI (CUDA 12.6 backend - PyTorch 2.6) - Git version"
arch=('x86_64')
url="https://github.com/Comfy-Org/ComfyUI"
license=('GPL3')
depends=(
  'python313'
  'git'
  'acl'
)
makedepends=('git')
provides=('comfyui' 'comfyui-cu126')
conflicts=('comfyui' 'comfyui-git' 'comfyui-cu126')
install="${pkgname}.install"

source=(
  "${pkgname}::git+https://github.com/Comfy-Org/ComfyUI.git#branch=master"
  "comfyui.service"
  "extra_model_paths.yaml"
  "setup.sh"
)

sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')

_appdir="/opt/${_pkgname}"

pkgver() {
  local repo="${srcdir:-.}/${pkgname}"

  if [[ -d "$repo/.git" ]]; then
    printf "r%s.%s" \
      "$(git -C "$repo" rev-list --count HEAD)" \
      "$(git -C "$repo" rev-parse --short=8 HEAD)"
  elif [[ -d .git ]]; then
    printf "r%s.%s" \
      "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=8 HEAD)"
  else
    return 1
  fi
}

prepare() {
  cd "$srcdir/$pkgname"
  git submodule update --init --recursive

  msg "Patching requirements.txt for CUDA 12.6 (PyTorch 2.6)..."

  # 1. Extra index URL beszúrása a fájl elejére
  sed -i '1i--extra-index-url https://download.pytorch.org/whl/cu126' requirements.txt

  # 2. Torch csomagok fix verzióinak beállítása
  sed -i \
    -e 's/^torch[[:space:]]*$/torch==2.6.0/' \
    -e 's/^torchvision[[:space:]]*$/torchvision==0.21.0/' \
    -e 's/^torchaudio[[:space:]]*$/torchaudio==2.6.0/' \
    -e 's/^torchsde[[:space:]]*$/torchsde==0.2.6/' \
    requirements.txt

  # Ellenőrzés
  if ! grep -q 'torch==2.6.0' requirements.txt; then
    error "Failed to patch torch version in requirements.txt"
    return 1
  fi

  # Egyedi kiegészítő fájlok másolása
  cp -v "$srcdir/extra_model_paths.yaml" .
  cp -v "$srcdir/setup.sh" .
}

package() {
  install -Dm644 "$srcdir/comfyui.service" \
    "$pkgdir/usr/lib/systemd/system/comfyui.service"

  install -d -m 2775 "$pkgdir${_appdir}"
  cp -a "$srcdir/$pkgname/." "$pkgdir${_appdir}/"

  # Biztonsági törlés: build-maradvány vagy véletlenül létrejött venv ne csússzon be a csomagba
  rm -rf "$pkgdir${_appdir}/venv"

  # Szimbolikus linkek meglévő modellekhez
  ln -s /opt/stable-diffusion-webui-forge/models/VAE-approx "$pkgdir${_appdir}/models/vae_approx/approx"
  ln -s /opt/stable-diffusion-webui-forge/models/VAE-taesd "$pkgdir${_appdir}/models/vae_approx/taesd"

  find "$pkgdir${_appdir}" -type d -exec chmod 2775 {} \;
  find "$pkgdir${_appdir}" -type f -exec chmod 664 {} \;
  find "$pkgdir${_appdir}" -type f -name "*.sh" -exec chmod 775 {} \;

  rm -rf "$pkgdir${_appdir}/.git"
  rm -rf "$pkgdir${_appdir}/.github"
}