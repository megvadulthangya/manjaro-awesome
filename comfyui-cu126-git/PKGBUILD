# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname="ComfyUI"
pkgname="comfyui-cu126-git"
pkgver=r4950.589228e6
pkgrel=1
pkgdesc="ComfyUI GUI (CUDA 12.6 backend - PyTorch 2.6) - Git version"
arch=('x86_64')
url="https://github.com/Comfy-Org/ComfyUI"
license=('GPL3')
depends=(
  'python313'
  'git'
  'byobu'
  'acl'
)
makedepends=('git')
provides=('comfyui' 'comfyui-cu126')
conflicts=('comfyui' 'comfyui-git' 'comfyui-cu126')
install="${pkgname}.install"

source=(
  "${pkgname}::git+https://github.com/Comfy-Org/ComfyUI.git#branch=master"
  "comfyui.service"
  "requirements.txt"
  "extra_model_paths.yaml"
  "setup.sh"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

_appdir="/opt/${_pkgname}"

pkgver() {
  local repo="${srcdir:-.}/${pkgname}"

  if [[ -d "$repo/.git" ]]; then
    printf "r%s.%s" \
      "$(git -C "$repo" rev-list --count HEAD)" \
      "$(git -C "$repo" rev-parse --short=8 HEAD)"
  else
    printf "r%s.%s" \
      "$(git rev-list --count HEAD)" \
      "$(git rev-parse --short=8 HEAD)"
  fi
}

prepare() {
  cd "$srcdir/$pkgname"
  git submodule update --init --recursive

  cp -v "$srcdir/requirements.txt" "requirements.txt"
  cp -v "$srcdir/extra_model_paths.yaml" "extra_model_paths.yaml"
  cp -v "$srcdir/setup.sh" "setup.sh"
}

package() {
  install -Dm644 "$srcdir/comfyui.service" \
    "$pkgdir/usr/lib/systemd/system/comfyui.service"

  install -d -m 2775 "$pkgdir${_appdir}"
  cp -a "$srcdir/$pkgname/." "$pkgdir${_appdir}/"

  python3.13 -m venv "$pkgdir${_appdir}/venv"

  mkdir -p "$pkgdir${_appdir}/models/vae-approx"
  ln -s /opt/stable-diffusion-webui-forge/models/VAE-approx "$pkgdir${_appdir}/models/vae-approx/approx"
  ln -s /opt/stable-diffusion-webui-forge/models/VAE-taesd "$pkgdir${_appdir}/models/vae-approx/taesd"

  find "$pkgdir${_appdir}" -type d -exec chmod 2775 {} \;
  find "$pkgdir${_appdir}" -type f -not -path "*/venv/bin/*" -exec chmod 664 {} \;
  find "$pkgdir${_appdir}" -type f -name "*.sh" -exec chmod 775 {} \;

  if [ -d "$pkgdir${_appdir}/venv/bin" ]; then
    find "$pkgdir${_appdir}/venv/bin" -type f -exec chmod 775 {} \;
  fi

  rm -rf "$pkgdir${_appdir}/.git"
  rm -rf "$pkgdir${_appdir}/.github"
}
