# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname="ComfyUI"
pkgname="comfyui-cu126"
pkgver=0.4.2   # <- kézzel frissíthető, vagy használhatsz pkgver() függvényt API-val
pkgrel=1
pkgdesc="ComfyUI GUI (CUDA 12.6 backend - PyTorch 2.6) - Stable release version"
arch=('x86_64')
url="https://github.com/Comfy-Org/ComfyUI"
license=('GPL3')
depends=(
  'python313'
  'git'
  'acl'
)
makedepends=('git' 'curl' 'jq')  # jq az API válasz feldolgozásához, opcionális
provides=('comfyui' 'comfyui-cu126')
conflicts=('comfyui' 'comfyui-git' 'comfyui-cu126-git')
install="${pkgname}.install"

# Forrás: a megadott tag archivált tömörített változata
_tag="v${pkgver}"
source=(
  "${pkgname}-${pkgver}.tar.gz::https://github.com/Comfy-Org/ComfyUI/archive/refs/tags/${_tag}.tar.gz"
  "comfyui.service"
  "extra_model_paths.yaml"
  "setup.sh"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP')  # élesben érdemes generálni `updpkgsums`-el

_appdir="/opt/${_pkgname}"

# Opcionális: automatikus pkgver frissítés a GitHub API alapján
# pkgver() {
#   curl -s "https://api.github.com/repos/Comfy-Org/ComfyUI/releases/latest" | \
#     jq -r '.tag_name' | sed 's/^v//'
# }

prepare() {
  cd "$srcdir/ComfyUI-${pkgver}"

  msg "Patching requirements.txt for CUDA 12.6 (PyTorch 2.6)..."

  # Ugyanaz a patchelés, mint korábban
  sed -i '1i--extra-index-url https://download.pytorch.org/whl/cu126' requirements.txt
  sed -i \
    -e 's/^torch[[:space:]]*$/torch==2.6.0/' \
    -e 's/^torchvision[[:space:]]*$/torchvision==0.21.0/' \
    -e 's/^torchaudio[[:space:]]*$/torchaudio==2.6.0/' \
    -e 's/^torchsde[[:space:]]*$/torchsde==0.2.6/' \
    requirements.txt

  if ! grep -q 'torch==2.6.0' requirements.txt; then
    error "Failed to patch torch version"
    return 1
  fi

  cp -v "$srcdir/extra_model_paths.yaml" .
  cp -v "$srcdir/setup.sh" .
}

package() {
  install -Dm644 "$srcdir/comfyui.service" \
    "$pkgdir/usr/lib/systemd/system/comfyui.service"

  install -d -m 2775 "$pkgdir${_appdir}"
  cp -a "$srcdir/ComfyUI-${pkgver}/." "$pkgdir${_appdir}/"

  rm -rf "$pkgdir${_appdir}/venv"

  ln -s /opt/stable-diffusion-webui-forge/models/VAE-approx "$pkgdir${_appdir}/models/vae_approx/approx"
  ln -s /opt/stable-diffusion-webui-forge/models/VAE-taesd "$pkgdir${_appdir}/models/vae_approx/taesd"

  find "$pkgdir${_appdir}" -type d -exec chmod 2775 {} \;
  find "$pkgdir${_appdir}" -type f -exec chmod 664 {} \;
  find "$pkgdir${_appdir}" -type f -name "*.sh" -exec chmod 775 {} \;

  rm -rf "$pkgdir${_appdir}/.git"   # release csomagban nincs .git, de biztos ami biztos
  rm -rf "$pkgdir${_appdir}/.github"
}