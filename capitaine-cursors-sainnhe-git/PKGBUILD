# Maintainer: Sainnhe Park <sainnhe@gmail.com>

pkgname=capitaine-cursors-sainnhe-git
pkgver=5.r22.gff16e74
pkgrel=1
pkgdesc="Sainnhe's fork of capitaine cursor theme, patched with some additional variants (Gruvbox, Nord, Palenight)"
arch=(any)
url="https://github.com/sainnhe/capitaine-cursors"
license=(LGPL3)
source=("git+${url}.git#branch=master")
provides=('capitaine-cursors')
conflicts=('capitaine-cursors')
makedepends=(
  git
  libx11
  libxcursor
  libpng
  nodejs
  yarn
  python
  python-pip
  nss
  alsa-lib
  atk
  at-spi2-atk
  cups
  gtk3
  libdrm
  libxcomposite
  libxdamage
  libxrandr
  mesa
  pango
  ttf-liberation
  chromium
)
sha256sums=('SKIP')

pkgver() {
  cd "${srcdir}/capitaine-cursors"
  git describe origin/master --long --tags | sed 's/^r//;s/\([^-]*-g\)/r\1/;s/-/./g'
}

prepare() {
  cd "${srcdir}/capitaine-cursors"

  # Python virtuális környezet a kompatibilis clickgen számára
  python3 -m venv builder/venv
  builder/venv/bin/pip install clickgen==1.2.0
}

package() {
  cd "${srcdir}/capitaine-cursors"
  export NODE_ENV=development
  export PUPPETEER_SKIP_DOWNLOAD=true
  export PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

  # Node függőségek (csak egyszer kell, a git checkout nem törli a node_modules-t)
  cd bitmapper
  yarn install
  cd ..

  install -Ddm755 "$pkgdir/usr/share/icons"
  for style in Default Nord Gruvbox Palenight ; do
    ./patch.sh "${style}"

    # Alapvető javítások, amiket a git checkout felülír
    sed -i 's/npx tsc --build/tsc --build/' bitmapper/packages/dark/package.json
    sed -i 's/npx tsc --build/tsc --build/' bitmapper/packages/light/package.json

    # Puppeteer argumentumok
    sed -i '/ignoreDefaultArgs:/d' bitmapper/packages/core/src/BitmapsGenerator.ts
    sed -i '/headless: true,/a\
      args: [\
        "--no-sandbox",\
        "--disable-setuid-sandbox",\
        "--disable-dev-shm-usage",\
      ],' bitmapper/packages/core/src/BitmapsGenerator.ts

    # Builder Makefile átírása (setup üres + venv python használata)
    cd builder
    sed -i 's/^setup:.*/setup:\n\t@true/' Makefile
    sed -i 's|@python3 build.py|@./venv/bin/python build.py|g' Makefile
    cd ..

    # Render + build
    make -C bitmapper install render_dark render_light
    make -C builder build_unix

    cp -dr --no-preserve=ownership themes/* "$pkgdir/usr/share/icons/"
    git checkout -- .
  done
}