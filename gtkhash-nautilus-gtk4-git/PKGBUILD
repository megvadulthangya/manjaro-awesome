# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

pkgname=gtkhash-nautilus-gtk4-git
pkgver=r1041.002be78
pkgrel=1
pkgdesc="A GTK4 utility for computing message digests or checksums (Gtkhash with Nautilus GTK4 plugin, git version)"
arch=('x86_64')
url="https://github.com/megvadulthangya/gtkhash"
license=('GPL')
depends=(
    'dconf'
    'gtk4'          # GTK3 helyett GTK4 kell az alaprendszernek
    'nautilus'      # A GTK4-es Nautilus
    'libb2'
    'libgcrypt'
    'nettle'
    'mbedtls'
)
makedepends=(
    'appstream-glib'
    'git'
    'intltool'
    'librsvg'
    'meson'
    'xdg-utils'
    'mbedtls'
)
provides=("gtkhash")
conflicts=('gtkhash' 'gtkhash-thunar-git' 'gtkhash-caja' 'gtkhash-nemo')
source=("gtkhash::git+https://github.com/megvadulthangya/gtkhash.git#branch=gtk4") # Átváltva a gtk4 branchre!
md5sums=('SKIP')

pkgver() {
  cd "$srcdir/gtkhash"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/gtkhash"
  # Mindig a legfrissebb gtk4 branch állapotra állunk rá
  git fetch origin gtk4
  git checkout gtk4
  git reset --hard origin/gtk4
}

build() {
  # Itt adjuk át a GTK4 build opciót, és a Nautilus plugint kapcsoljuk be
  arch-meson "$srcdir/gtkhash" build \
    -Dgtk_version=4 \
    -Dwerror='false' \
    -Dglib-checksums='true' \
    -Dlinux-crypto='true' \
    -Dnettle='true' \
    -Dmbedtls='true' \
    -Dlibcrypto='true' \
    -Dbuild-caja='false' \
    -Dbuild-nautilus='true' \
    -Dbuild-nemo='false' \
    -Dbuild-thunar='false'
  meson compile -C build
}

check() {
  desktop-file-validate build/data/*.desktop
  appstream-util validate-relax --nonet build/data/appdata/*.appdata.xml
}

package() {
  meson install -C build --destdir "$pkgdir"
}
