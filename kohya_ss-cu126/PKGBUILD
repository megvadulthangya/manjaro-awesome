# Maintainer: Gyöngyösi Gábor <gabor at gshoots dot hu>

_pkgname="kohya_ss"
pkgname="kohya_ss-cu126"
pkgver=r3371.4161d1d8
pkgrel=1
pkgdesc="Kohya_ss GUI (CUDA 12.6 backend) — supports NVIDIA GPUs with Compute Capability ≥5.0 (Kepler/Maxwell/Pascal/Volta/Turing/Ampere/Ada)"
arch=('x86_64')
url="https://github.com/bmaltais/kohya_ss"
license=('Apache')
depends=(
  'git'
  'acl'
  'byobu'
)
makedepends=('git')
provides=('kohya_ss')
conflicts=('kohya_ss' 'kohya_ss-cu124')
install="${pkgname}.install"

source=(
  "${pkgname}::git+https://github.com/bmaltais/kohya_ss.git#branch=master"
  "kohya_ss.service"
  "requirements.txt"
  "requirements_linux.txt"
  "requirements_linux_docker.txt"
  "requirements_linux_ipex.txt"
  "requirements_linux_rocm.txt"
  "requirements_macos_amd64.txt"
  "requirements_macos_arm64.txt"
  "requirements_pytorch_windows.txt"
  "requirements_runpod.txt"
  "requirements_windows.txt"
  "setup.sh"
)
sha256sums=('SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP' 'SKIP')

_appdir="/opt/${_pkgname}"

pkgver() {
  cd "$srcdir/$pkgname"
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

prepare() {
  cd "$srcdir/$pkgname"
  # Initialize submodules to ensure all dependencies are present
  git submodule update --init --recursive
  # Overlay CUDA 12.6 specific requirements and files
  cp -v "$srcdir"/requirements*.txt .
  # Overlay setup.sh from the same directory as PKGBUILD
  cp -v "$srcdir/setup.sh" .
}

package() {
  # systemd unit
  install -Dm644 "$srcdir/kohya_ss.service" \
    "$pkgdir/usr/lib/systemd/system/kohya_ss.service"

  # alkalmazás fájlok másolása az /opt/kohya_ss-be, SGID bites joggal
  install -d -m 2775 "$pkgdir${_appdir}"
  cp -a "$srcdir/$pkgname/." "$pkgdir${_appdir}/"
  
  # GUI.SH herélése: Töröljük azt a blokkot, ami sudo-t akar hívni a diffusion user nevében
sed -i '/if \[ -n "\$SUDO_USER" \] || \[ -n "\$SUDO_COMMAND" \]; then/,/fi/d' "$pkgdir${_appdir}/gui.sh"
  
  # Symlink létrehozása
  ln -s /opt/stable-diffusion-webui-forge/models/Stable-diffusion "$pkgdir${_appdir}/models/Stable-diffusion"
  
  # .sh fájlok futtathatóvá tétele
  find "$pkgdir${_appdir}" -type f -name "*.sh" -exec chmod +x {} \;
  
  rm -rf "$pkgdir${_appdir}/.git"
  rm -rf "$pkgdir${_appdir}/.github"
  # .gitmodules and submodules are kept
}
